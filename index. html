<script>
let cur='pi';
function ir(id){document.getElementById(cur).classList.remove('a');document.getElementById(id).classList.add('a');cur=id;window.scrollTo(0,0);if(id==='pr')iR();if(id==='pno'){cNo();rP();}if(id==='pl')rL();if(id==='pca')iC();if(id==='pkal')rCal();}
function v(){document.getElementById(cur).classList.remove('a');document.getElementById('pi').classList.add('a');cur='pi';window.scrollTo(0,0);}
function ab(u){window.open(u,'_blank');}
setTimeout(()=>{const a=document.getElementById('av');if(a)a.classList.add('ok');},3000);
function toast(m){const t=document.getElementById('toast');t.textContent=m;t.classList.add('v');setTimeout(()=>t.classList.remove('v'),2800);}
function bG(){const q=(document.getElementById('bi').value||'').trim();if(!q){toast('✏️ Escribe qué quieres buscar');return;}window.open('https://www.google.com/search?q='+encodeURIComponent(q),'_blank');}
function ll(){const n=document.getElementById('it').value.trim();if(!n){toast('✏️ Escribe un número primero');return;}window.location.href='tel:'+n;}
let cV='0',cO=null,cA=null,cNu=false;
function cN(n){if(cNu){cV=n==='.'?'0.':n;cNu=false;}else{if(n==='.'&&cV.includes('.'))return;cV=cV==='0'&&n!=='.'?n:cV+n;}document.getElementById('cd2').textContent=cV;}
function cOp(o){if(o==='±'){cV=String(-parseFloat(cV));document.getElementById('cd2').textContent=cV;return;}if(o==='%'){cV=String(parseFloat(cV)/100);document.getElementById('cd2').textContent=cV;return;}cA=parseFloat(cV);cO=o;cNu=true;document.getElementById('cp2').textContent=cV+' '+o;}
function cIg(){if(!cO||cA===null)return;const b=parseFloat(cV);let r;if(cO==='+')r=cA+b;else if(cO==='−')r=cA-b;else if(cO==='×')r=cA*b;else if(cO==='÷')r=b!==0?cA/b:'Error';cV=String(Math.round(r*1e10)/1e10);document.getElementById('cd2').textContent=cV;document.getElementById('cp2').textContent='';cO=null;cA=null;cNu=true;}
function cAC(){cV='0';cO=null;cA=null;cNu=false;document.getElementById('cd2').textContent='0';document.getElementById('cp2').textContent='';}
let sc=null;
async function iC(){const e=document.getElementById('ce'),vd=document.getElementById('vc');try{e.textContent='📷 Pidiendo permiso de cámara...';e.style.display='block';sc=await navigator.mediaDevices.getUserMedia({video:{facingMode:'environment'},audio:false});vd.srcObject=sc;vd.style.display='block';e.style.display='none';}catch(er){vd.style.display='none';e.textContent=er.name==='NotAllowedError'?'❌ Permiso denegado. Ve a Configuración de Chrome → Configuración del sitio → Cámara y actívala.':'❌ No se pudo acceder a la cámara.';}}
function tF(){const vd=document.getElementById('vc'),c=document.getElementById('cc');if(!sc){toast('📷 Espera a que la cámara cargue');return;}c.width=vd.videoWidth;c.height=vd.videoHeight;c.getContext('2d').drawImage(vd,0,0);const img=document.getElementById('fp');img.src=c.toDataURL('image/jpeg',.92);img.style.display='block';toast('✅ Foto tomada');}
