function pC(){if(sc){sc.getTracks().forEach(t=>t.stop());sc=null;}}
function bY(){const q=document.getElementById('iy').value.trim();if(!q){toast('✏️ Escribe qué quieres buscar');return;}window.open('https://www.youtube.com/results?search_query='+encodeURIComponent(q),'_blank');}
function tN(t,b){document.querySelectorAll('.tta').forEach(x=>x.classList.remove('ac'));document.querySelectorAll('.sn').forEach(x=>x.classList.remove('ac'));document.getElementById('tab-'+t).classList.add('ac');b.classList.add('ac');if(t==='pendientes')rP();}
function gNo(){localStorage.setItem('notas',document.getElementById('tn').value);toast('✅ Notas guardadas');}
function cNo(){const n=localStorage.getItem('notas');if(n)document.getElementById('tn').value=n;}
function gP(){return JSON.parse(localStorage.getItem('pend')||'[]');}
function sP(p){localStorage.setItem('pend',JSON.stringify(p));}
function aP(){const i=document.getElementById('ip2'),t=i.value.trim();if(!t)return;const p=gP();p.push({id:Date.now(),texto:t,hecho:false});sP(p);i.value='';rP();toast('✅ Tarea agregada');}
function rP(){const l=document.getElementById('lp2');if(!l)return;const p=gP();if(p.length===0){l.innerHTML='<div class="ic2">Sin tareas aún.</div>';return;}l.innerHTML=p.map(t=>`<div class="ip ${t.hecho?'he':''}"><div class="ch ${t.hecho?'ma':''}" onclick="tP(${t.id})">${t.hecho?'✓':''}</div><div class="tp">${t.texto}</div><button class="dp" onclick="bP(${t.id})">✕</button></div>`).join('');}
function tP(id){sP(gP().map(t=>t.id===id?{...t,hecho:!t.hecho}:t));rP();}
function bP(id){sP(gP().filter(t=>t.id!==id));rP();}
function gLi(){return JSON.parse(localStorage.getItem('links')||'[]');}
function sL(l){localStorage.setItem('links',JSON.stringify(l));}
function gL(){const n=document.getElementById('ln').value.trim();let u=document.getElementById('lu').value.trim();if(!n||!u){toast('✏️ Escribe nombre y URL');return;}if(!u.startsWith('http'))u='https://'+u;const l=gLi();l.push({id:Date.now(),nombre:n,url:u});sL(l);document.getElementById('ln').value='';document.getElementById('lu').value='';rL();toast('🔗 Link guardado');}
function rL(){const li=document.getElementById('ll2');if(!li)return;const l=gLi();if(l.length===0){li.innerHTML='<div class="ic2">Sin links guardados aún.</div>';return;}li.innerHTML=l.map(lk=>`<div class="il"><div class="li"><div class="ln">🌐 ${lk.nombre}</div><div class="lu">${lk.url}</div></div><button class="bo2" onclick="window.open('${lk.url}','_blank')">Abrir</button><button class="bd" onclick="bL(${lk.id})">✕</button></div>`).join('');}
function bL(id){sL(gLi().filter(l=>l.id!==id));rL();toast('🗑️ Link eliminado');}
let ri=null;
function iR(){aR();if(ri)clearInterval(ri);ri=setInterval(aR,1000);}
function aR(){const n=new Date(),h=String(n.getHours()).padStart(2,'0'),m=String(n.getMinutes()).padStart(2,'0'),s=String(n.getSeconds()).padStart(2,'0');document.getElementById('rh').textContent=h+':'+m;document.getElementById('rs2').textContent=':'+s;const ds=['domingo','lunes','martes','miércoles','jueves','viernes','sábado'],ms=['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];document.getElementById('rf').textContent=ds[n.getDay()]+', '+n.getDate()+' de '+ms[n.getMonth()]+' de '+n.getFullYear();}
let cY=new Date().getFullYear(),cMo=new Date().getMonth();
function cM(d){cMo+=d;if(cMo>11){cMo=0;cY++;}if(cMo<0){cMo=11;cY--;}rCal();}
function rCal(){const ms=['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];document.getElementById('cti').textContent=ms[cMo]+' '+cY;const h=new Date(),pd=new Date(cY,cMo,1).getDay(),of=pd===0?6:pd-1,dm=new Date(cY,cMo+1,0).getDate();let html='';for(let i=0;i<of;i++)html+='<div class="cd va"></div>';for(let d=1;d<=dm;d++){const ds=new Date(cY,cMo,d).getDay(),fi=ds===0||ds===6,hoy=d===h.getDate()&&cMo===h.getMonth()&&cY===h.getFullYear();html+=`<div class="cd ${fi?'fi':''} ${hoy?'ho2':''}">${d}</div>`;}document.getElementById('cg2').innerHTML=html;}
cNo();rP();rL();
